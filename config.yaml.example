# Obsidian to Notion Migration Configuration

# Notion settings
notion:
  # Parent page ID where imported pages will be created
  # Can be overridden by NOTION_PARENT_PAGE_ID environment variable
  parent_page_id: ""

  # Maximum number of retries for API requests
  max_retries: 3

  # Number of pages to process in batch
  batch_size: 10

# Obsidian vault settings
obsidian:
  # Patterns to skip during migration (relative to vault root)
  skip_patterns:
    - ".obsidian/"
    - ".trash/"
    - "_templates/"
    - "_archive/"

  # File extensions considered as attachments
  attachment_extensions:
    - .png
    - .jpg
    - .jpeg
    - .gif
    - .pdf
    - .mp4
    - .mov
    - .zip
    - .docx
    - .xlsx

# Migration settings
migration:
  # How to handle duplicate pages in Notion
  # Options: skip, update, create_new
  duplicate_handling: skip

  # Whether to migrate tags as Notion labels
  migrate_tags: true

  # Whether to migrate frontmatter as page properties
  migrate_frontmatter: true

  # Whether to preserve folder structure as nested pages
  preserve_folder_structure: true

  # Maximum depth for nested pages (0 = unlimited)
  max_nesting_depth: 0

# Advanced settings
advanced:
  # Whether to convert wikilinks to Notion page mentions
  convert_wikilinks: true

  # Whether to upload attachments (requires external hosting)
  upload_attachments: false

  # External file hosting settings (if upload_attachments is true)
  file_hosting:
    # Options: s3, cloudinary, local_server
    provider: ""
    # Provider-specific settings
    settings: {}
