# Notion API Configuration
# Get your integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# Optional: Notion workspace ID
# If not provided, will use the default workspace
NOTION_WORKSPACE_ID=

# Optional: Parent page ID for imported content
# If not provided, will need to specify in config.yaml
NOTION_PARENT_PAGE_ID=